{
  "name": "@react-mcp-spa/mcp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "react-mcp-spa": "dist/main.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-ui.mjs",
    "serve": "node --enable-source-maps dist/main.js",
    "serve:stdio": "node --enable-source-maps dist/main.js --stdio",
    "dev": "tsc --watch",
    "start": "pnpm run build && pnpm run serve"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  }
}
